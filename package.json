{
  "name": "pi-design-system",
  "version": "0.1.0",
  "description": "Pi Design System — tokens & components (SCSS). 前端切版對照用，不發布 npm。",
  "scripts": {
    "build": "sass src/index.scss dist/pi-ds.css --style=expanded --no-source-map",
    "build:min": "sass src/index.scss dist/pi-ds.min.css --style=compressed --no-source-map",
    "build:tokens": "sass src/tokens/index.scss dist/pi-ds-tokens.css --style=expanded --no-source-map",
    "watch": "sass --watch src/index.scss:dist/pi-ds.css --style=expanded --no-source-map",
    "lint:scss": "stylelint \"src/**/*.scss\"",
    "dev": "vite",
    "preview:build": "vite build",
    "preview:serve": "vite preview",
    "test": "npm run build && grep -q -- '--cl-green-500' dist/pi-ds.css && grep -q '.gl_btn' dist/pi-ds.css && echo 'smoke test passed'"
  },
  "devDependencies": {
    "sass": "^1.77.0",
    "vite": "^8.0.0"
  },
  "keywords": [
    "design-system",
    "scss",
    "tokens",
    "pi"
  ],
  "license": "UNLICENSED",
  "private": true
}
